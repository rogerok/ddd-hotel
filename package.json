{
  "name": "ddd-hotel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/platform/server/main.ts",
    "dev": "concurrently -k -n api,web \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "cross-env NODE_ENV=development node --watch src/platform/server/main.ts",
    "dev:web": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@fastify/static": "^8.3.0",
    "effect": "^3.22.0",
    "fastify": "^5.10.0",
    "mobx": "^6.16.1",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^3.2.7",
    "concurrently": "^9.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.4.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  },
  "packageManager": "pnpm@10.25.0"
}
